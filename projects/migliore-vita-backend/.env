# Environment Configuration
# Copy to .env and fill in values — DO NOT commit .env to git

# ── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=migliore_vita_development
DB_USER=migliore_vita
DB_PASSWORD=secure_password_123

# ── Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ── AWS ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here
AWS_REGION=me-south-1
S3_BUCKET=migliore-vita-media

# ── Google Drive ───────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ── Twilio (WhatsApp/SMS) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Email ──────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@migliore-vita.eg

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://5.189.160.78:5174,http://5.189.160.78:5000,https://admin.migliore-vita.eg,http://5.189.160.78:5175,http://5.189.160.78:5176

# ── Redis (optional, for caching) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
